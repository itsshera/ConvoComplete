# ConvoComplete environment placeholders
# Copy this file to .env only for local private development.
# Never commit real keys, customer data, or private URLs.

APP_NAME=ConvoComplete
APP_ENV=development
APP_PORT=4000

# Database placeholder
DATABASE_URL=postgres://user:password@localhost:5432/convocomplete_dev

# AI provider placeholders
AI_PROVIDER=placeholder
AI_API_KEY=replace_with_real_key_later

# Speech-to-text provider placeholders
STT_PROVIDER=placeholder
STT_API_KEY=replace_with_real_key_later

# Optional integration placeholders
CRM_PROVIDER=placeholder
CRM_API_KEY=replace_with_real_key_later
CALENDAR_PROVIDER=placeholder
CALENDAR_API_KEY=replace_with_real_key_later

# Upload settings placeholders
MAX_AUDIO_UPLOAD_MB=100
ALLOWED_AUDIO_TYPES=mp3,wav,m4a,ogg

# Security placeholders
SESSION_SECRET=replace_with_long_random_secret_later
JWT_SECRET=replace_with_long_random_secret_later
